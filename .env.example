# Gyeongguk MCP 환경변수 — 이 파일을 .env 로 복사해 값을 채운다.
# .env 는 .gitignore 로 커밋에서 제외된다.

# [필수] 국가법령정보센터(법제처) OPEN API 키 (OC 값)
#  발급: https://open.law.go.kr/  →  마이페이지 OPEN API 활용신청 → 이메일 ID 부분이 OC 값
LAW_API_KEY=

# [선택] solve_record 의 auto 모드(서버 내부에서 LLM이 전 단계를 자동 수행)에만 필요.
#  없으면 auto 모드는 비활성화되고, 호스트 LLM(예: Claude Code)이 단계 플레이북을 받아 직접 수행한다.
ANTHROPIC_API_KEY=

# [선택] auto 모드에서 사용할 모델 (기본: claude-opus-4-8)
GIROK_AUTO_MODEL=claude-opus-4-8

# [선택] opendataloader hybrid(스캔 PDF OCR) 서버 주소. 미설정 시 네이티브(디지털) 추출만.
#  실행: pip install "opendataloader-pdf[hybrid]" && opendataloader-pdf-hybrid --port 5002 --ocr-lang "ko,en"
GIROK_ODL_HYBRID=
